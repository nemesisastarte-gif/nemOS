        }
    ]
}
CATALOG_EOF
        echo "     -> package-catalog.json (généré)"
    fi

    # --- Fichier desktop ---
    echo "  -> Installation du fichier .desktop..."
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/nemos-store.desktop" << 'DESKTOP_EOF'
[Desktop Entry]
Name=nemOS Store
Comment=Boutique d'applications nemOS
Comment[fr]=Boutique d'applications nemOS
Exec=/usr/lib/nemos-store/nemos-store.py
Icon=nemos-store
Type=Application
Categories=System;PackageManager;
Keywords=store;app;install;paquet;boutique;
StartupNotify=true
StartupWMClass=nemos-store
Terminal=false
DESKTOP_EOF

    # --- Icône ---
    echo "  -> Installation de l'icône..."
    if [ -f "${srcdir}/nemos-store.svg" ]; then
        install -Dm644 "${srcdir}/nemos-store.svg" \
            "${pkgdir}/usr/share/icons/hicolor/scalable/apps/nemos-store.svg"
        echo "     -> nemos-store.svg"
    fi

    # --- Lien symbolique pour l'exécutable ---
    echo "  -> Création du lien d'exécution..."
    mkdir -p "${pkgdir}/usr/bin"
    ln -sf "/usr/lib/nemos-store/nemos-store.py" \
           "${pkgdir}/usr/bin/nemos-store"

    # --- Politique PolicyKit ---
    echo "  -> Installation des règles PolicyKit..."
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/polkit-1/rules.d/50-nemos-store.rules" << 'POLKIT_EOF'
// Règles PolicyKit pour nemOS Store
// Permet l'installation de paquets via l'interface graphique

polkit.addRule(function(action, subject) {
    // Autoriser l'installation de paquets pour les utilisateurs du groupe wheel
    if (action.id.indexOf("org.freedesktop.packagekit.") === 0 ||
        action.id === "org.archlinux.pacman.install" ||
        action.id === "org.archlinux.pacman.remove") {
        if (subject.isInGroup("wheel")) {
            return polkit.Result.YES;
        }
    }
});
POLKIT_EOF

    # Permissions
    find "${pkgdir}" -type d -exec chmod 755 {} \;
    find "${pkgdir}" -type f -exec chmod 644 {} \;
    chmod 755 "${appdir}/nemos-store.py" 2>/dev/null || true

    # Document
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/doc/${pkgname}/README" << 'README_EOF'
nemOS-Store - Boutique d'applications nemOS
============================================

Interface graphique de gestion de paquets pour nemOS.
Style inspiré de l'App Store macOS.

Fonctionnalités :
  - Recherche de paquets
  - Navigation par catégories
  - Installation/uninstallation via pacman
  - Support AUR (via pamac)
  - Support Flatpak

Démarrage :
  - Menu : Applications > Système > nemOS Store
  - Terminal : nemos-store
  - Raccourci : Alt+F2 > nemos-store

Fichier de catalogue :
  /usr/lib/nemos-store/package-catalog.json

Pour ajouter des paquets au catalogue, éditer le fichier JSON
et ajouter une entrée dans le tableau "packages".
README_EOF

    echo "  -> Paquet ${pkgname}-${pkgver}-${pkgrel} prêt."
}