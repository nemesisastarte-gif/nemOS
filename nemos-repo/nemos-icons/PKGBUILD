# Mainteneur : nemOS <contact@nemos.dev>
# Paquet : nemos-icons
# Thème d'icônes personnalisé pour nemOS, style macOS épuré

pkgname=nemos-icons
pkgver=1.0.0
pkgrel=1
pkgdesc="Thème d'icônes pour nemOS - Style macOS épuré"
arch=('i686' 'x86_64')
url="https://nemos.dev"
license=('GPL-3.0-or-later')
depends=('hicolor-icon-theme' 'adwaita-icon-theme')
makedepends=('git')
provides=('nemos-icon-theme')
conflicts=('nemos-icon-theme')
replaces=('nemos-icon-theme')
options=('!strip' '!debug')
source=(
    "16x16::git+file://${startdir}/src/16x16"
    "22x22::git+file://${startdir}/src/22x22"
    "24x24::git+file://${startdir}/src/24x24"
    "32x32::git+file://${startdir}/src/32x32"
    "48x48::git+file://${startdir}/src/48x48"
    "64x64::git+file://${startdir}/src/64x64"
    "128x128::git+file://${startdir}/src/128x128"
    "scalable::git+file://${startdir}/src/scalable"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')
noextract=(${source[@]%%::*})
# Remplacer les sommes de contrôle par 'SKIP' car ce sont des sources locales
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

# Référence : index.theme standard freedesktop
# https://specifications.freedesktop.org/icon-theme-spec/icon-theme-spec-latest.html

package() {
    # Point d'installation du thème d'icônes
    local themedir="${pkgdir}/usr/share/icons/nemOS-Icons"
    mkdir -p "${themedir}"

    # Tailles d'icônes supportées par le thème
    local sizes=(16x16 22x22 24x24 32x32 48x48 64x64 128x128 scalable)
    local contexts=(actions apps categories devices emblems mimetypes places status)

    # Copier chaque taille de répertoire d'icônes
    for size in "${sizes[@]}"; do
        if [ -d "${srcdir}/${size}" ]; then
            echo "  -> Installation des icônes ${size}..."
            cp -r "${srcdir}/${size}" "${themedir}/"
        else
            echo "  -> Création du répertoire vide ${size}..."
            mkdir -p "${themedir}/${size}"
            # Créer les sous-répertoires de contexte standards
            for ctx in "${contexts[@]}"; do
                mkdir -p "${themedir}/${size}/${ctx}"
            done
        fi
    done

    # Générer le fichier index.theme (standard freedesktop)
    echo "  -> Génération de index.theme..."
    cat > "${themedir}/index.theme" << 'INDEXTHEME_EOF'
[Icon Theme]
Name=nemOS-Icons
Comment=Thème d'icônes nemOS - Style macOS épuré
Inherits=Adwaita,hicolor

# Liste des répertoires avec leur taille et contexte
# Les répertoires sont classés du plus petit au plus grand
# GRUB/GTK choisit la taille la plus appropriée automatiquement

# Tailles fixes (pixels)
[16x16/Actions]
Size=16
Context=Actions
Type=Fixed
MinSize=16
MaxSize=16

[16x16/Apps]
Size=16
Context=Applications
Type=Fixed
MinSize=16
MaxSize=16

[16x16/Categories]
Size=16
Context=Categories
Type=Fixed
MinSize=16
MaxSize=16

[16x16/Devices]
Size=16
Context=Devices
Type=Fixed
MinSize=16
MaxSize=16

[16x16/Emblems]
Size=16
Context=Emblems
Type=Fixed
MinSize=16
MaxSize=16

